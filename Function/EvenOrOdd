//This was one of my first programs using Functions. After studying procedures, understandying functions became much easier.
//The goal of this program is to show if the number is even or odd.

algoritmo "ParOuImpar"
var
   N: Inteiro
   R: Caractere
   
Funcao ParOuImpar(V: Inteiro): Caractere
Inicio
   Se (V%2 = 0) entao
      Retorne "EVEN"
   Senao
      Retorne "ODD"
   FimSe
FimFuncao

inicio
   Escreva("Type a number: ")
   Leia(N)
   R <- ParOuImpar(N)
   Escreva ("The number ", N, " is an ", R," number")
fimalgoritmo
